## prep data for outcome regression models 

# std exposure within treated group 
# Function to standardize variables using treated group stats
standardize_att <- function(data, var_name, treated_idx, weights_var = "weights") {
  # Get the variable and weights
  var <- data[[var_name]]
  weights <- data[[weights_var]]
  
  # Calculate weighted mean and SD for treated group
  mean_treated <- wtd.mean(var[treated_idx], weights = weights[treated_idx])
  sd_treated <- sqrt(wtd.var(var[treated_idx], weights = weights[treated_idx]))
  
  # Standardize the entire variable
  standardized <- (var - mean_treated) / sd_treated
  
  return(standardized)
}

# Identify treated observations once
treated_idx <- matched_data_main$gvh1600_any == 1

# Apply standardization to all variables
vars_to_standardize <- c("gvh1600count", "dist_weight_count", "gvh1600_rate", "grmpc15", "phepc15", "pce15", "grmpc9", "phepc9", "pce9")

for (var in vars_to_standardize) {
  new_var_name <- paste0(var, "_att_std")
  matched_data_main[[new_var_name]] <- standardize_att(
    matched_data_main, 
    var, 
    treated_idx
  )
}

## recalculate Y15 and Y9 std biological aging summary scores for matched sample 
# Y15
model_Y15_std_matched <- 'bioage15_att =~ grmpc15_att_std + phepc15_att_std + pce15_att_std' 
fit_y15_std_matched <- cfa(model_Y15_std_matched, data=matched_data_main, std.lv = TRUE, sampling.weights = "weights")
summary(fit_y15_std_matched, fit.measures = TRUE, standardized = TRUE)
bioage15_pred <- data.frame(
  idnum = matched_data_main$idnum,
  bioage15_att = as.numeric(lavPredict(fit_y15_std_matched, newdata = matched_data_main)))
#matched_data_main <- merge(matched_data_main, bioage15_pred, by = "idnum", sort = FALSE)
# alt merge
matched_data_main <- dplyr::left_join(
  matched_data_main,
  bioage15_pred,
  by = "idnum"
)

