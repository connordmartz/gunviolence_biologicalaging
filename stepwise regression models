# standardized estimates 
out_main_list_std <- list(
  m1_bio = lm(bioage15_std ~ gvh1600count_std + age_t6 + female + momsmk + plasmablast_t6 + cd8pcd28ncd45ran_t6 + cd8naive_t6 + chip, data = df_final_full),
  m2_bio = lm(bioage15_std ~ gvh1600count_std + pov_t6 + edu_t6 + age_t6 + female + momsmk + plasmablast_t6 + cd8pcd28ncd45ran_t6 + cd8naive_t6 + chip, data = df_final_full),
  m3_bio = lm(bioage15_std ~ gvh1600count_std + pov_t6 + edu_t6 + trct_pct_pov_t6 + age_t6 + female + momsmk + plasmablast_t6 + cd8pcd28ncd45ran_t6 + cd8naive_t6 + chip, data = df_final_full),
  m4_bio = lm(bioage15_std ~ gvh1600count_std + race + pov_t6 + edu_t6 + trct_pct_pov_t6 + age_t6 + female + momsmk + plasmablast_t6 + cd8pcd28ncd45ran_t6 + cd8naive_t6 + chip, data = df_final_full),
  m5_bio = lm(bioage15_std ~ gvh1600count_std + vc_rate9_std + bioage9_std + age_t5 + plasmablast_t5 + cd8pcd28ncd45ran_t5 + cd8naive_t5 + pov_t5 + trct_pct_pov_t5 + race + pov_t6 + edu_t6 + trct_pct_pov_t6 + age_t6 + female + momsmk + plasmablast_t6 + cd8pcd28ncd45ran_t6 + cd8naive_t6 + chip, data = df_final_full))
results_main_std <- lapply(names(out_main_list_std), function(model_name) {
  model <- out_main_list_std[[model_name]]
  robust_se <- vcovHC(model, type = "HC1")
  robust_ci <- coefci(model, vcov. = robust_se, level = 0.95)
  robust_summary <- coeftest(model, vcov. = robust_se)
  tidy_model <- tidy(robust_summary) %>%
    mutate(
      conf.low = robust_ci[, 1],
      conf.high = robust_ci[, 2],
      model = model_name,
      summary = paste0(sprintf("%.3f", estimate), 
                       " (", sprintf("%.3f", conf.low), 
                       ", ", sprintf("%.3f", conf.high), ")")) %>%
    dplyr::select(model, term, summary)
  return(tidy_model)})
df_results_main_std <- do.call(rbind, results_main_std)

# model 1: 0.060 (0.037, 0.083)
print(df_results_main_std$summary[df_results_main_std$term=="gvh1600count_std" & df_results_main_std$model=="m1_bio"])

