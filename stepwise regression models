model_Y15_std <- 'bioage15std =~ grmpc15_std + phepc15_std + pce15_std'
fit_y15_std <- cfa(model_Y15_std, data=df_final_full, std.lv = TRUE)
summary(fit_y15_std, fit.measures = TRUE, standardized = TRUE)
data_used <- fit_y15_std@Data@X
used_rows_indices <- fit_y15_std@Data@case.idx[[1]]
bioage15_pred <- data.frame(
  idnum = df_final_full$idnum, 
  bioage15 = as.numeric(lavPredict(fit_y15_std, newdata = df_final_full)))
df_final_full <- dplyr::left_join(
  df_final_full,
  bioage15_pred,
  by = "idnum"
)
df_final_full$bioage15_std <- scale(df_final_full$bioage15)

